    Color burgundyColor = const Color(0xFF8A1C26);

    return Scaffold(
      body: Center(
        child: SingleChildScrollView(
          padding: const EdgeInsets.all(24.0),
          child: Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [
              Container(
                height: 120,
                width: 120,
                decoration: BoxDecoration(
                  color: tealColor.withOpacity(0.1),
                  shape: BoxShape.circle,
                ),
                child: Icon(Icons.medical_services_outlined, size: 60, color: tealColor),
              ),
              const SizedBox(height: 16),
              Text(
                'Physio First Step',
                style: TextStyle(fontSize: 28, fontWeight: FontWeight.bold, color: burgundyColor),
              ),
              Text(
                'أول خطوة في تحقيق نجاحك',
                style: TextStyle(fontSize: 16, color: Colors.grey[600]),
              ),
              const SizedBox(height: 32),
              Row(
