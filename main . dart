// -----------------------------------------------------------------
// 2. لوحة تحكم المحاضر الحقيقية (Admin Dashboard)
// -----------------------------------------------------------------
class AdminDashboard extends StatefulWidget {
  const AdminDashboard({Key? key}) : super(key: key);

  @override
  State<AdminDashboard> createState() => _AdminDashboardState();
}

class _AdminDashboardState extends State<AdminDashboard> {
  final _titleController = TextEditingController();
  final _linkController = TextEditingController();
  String selectedSection = 'محاضرات';
  bool isLoading = false;

  // دالة الرفع الحقيقية إلى Firebase Firestore
  void _uploadContentToFirebase() async {
    if (_titleController.text.isEmpty || _linkController.text.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text('برجاء ملء البيانات أولاً')));
      return;
    }

    setState(() => isLoading = true);

    try {
      // إرسال البيانات إلى جدول (Collection) يسمى "physio_content"
      await FirebaseFirestore.instance.collection('physio_content').add({
        'section': selectedSection,
        'title': _titleController.text.trim(),
        'url': _linkController.text.trim(),
        'createdAt': FieldValue.serverTimestamp(), // ترتيب تصاعدي حسب وقت الرفع
      });

      ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text('تم النشر بنجاح بجميع الأقسام ومزامنتها سحابياً!')));
      _titleController.clear();
      _linkController.clear();
    } catch (e) {
      ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text('حدث خطأ أثناء الرفع: $e')));
    } finally {
      setState(() => isLoading = false);
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('لوحة تحكم المحاضر الحقيقية', style: TextStyle(color: Colors.white)),
        backgroundColor: const Color(0xFF8A1C26), // Burgundy
        actions: [
          IconButton(
            icon: const Icon(Icons.logout, color: Colors.white),
            onPressed: () {
              Navigator.pushReplacement(context, MaterialPageRoute(builder: (context) => const LoginScreen()));
            },
          )
        ],
      ),
      body: Padding(
        padding: const EdgeInsets.all(16.0),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const Text('رفع محتوى جديد سحابياً:', style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold)),
            const SizedBox(height: 12),
            DropdownButtonFormField<String>(
              value: selectedSection,
              items: ['محاضرات', 'قسم الحل', 'ملفات PDF'].map((String category) {
                return DropdownMenuItem(value: category, child: Text(category));
              }).toList(),
              onChanged: (val) => setState(() => selectedSection = val!),
              decoration: InputDecoration(border: OutlineInputBorder(borderRadius: BorderRadius.circular(12))),
            ),
            const SizedBox(height: 12),
            TextField(
              controller: _titleController,
              decoration: InputDecoration(labelText: 'العنوان البسيط للمحتوى', border: OutlineInputBorder(borderRadius: BorderRadius.circular(12))),
            ),
            const SizedBox(height: 12),
            TextField(
              controller: _linkController,
              decoration: InputDecoration(labelText: 'الرابط (YouTube Unlisted أو PDF URL)', border: OutlineInputBorder(borderRadius: BorderRadius.circular(12))),
            ),
            const SizedBox(height: 16),
            SizedBox(
              width: double.infinity,
              height: 48,
              child: ElevatedButton(
                style: ElevatedButton.styleFrom(backgroundColor: const Color(0xFF8A1C26)),
                onPressed: isLoading ? null : _uploadContentToFirebase,
                child: isLoading 
                    ? const CircularProgressIndicator(color: Colors.white)
                    : const Text('نشر المحتوى فوراً', style: TextStyle(color: Colors.white, fontSize: 16)),
              ),
            ),
          ],
        ),
      ),
    );
  }
}

// -----------------------------------------------------------------
// 3. واجهة الطالب متزامنة مع السحاب (Student Dashboard)
// -----------------------------------------------------------------
class StudentDashboard extends StatelessWidget {
  const StudentDashboard({Key? key}) : super(key: key);

  @override
  Widget build(BuildContext context) {
    return DefaultTabController(
      length: 3,
      child: Scaffold(
        appBar: AppBar(
          title: const Text('Physio First Step', style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold)),
          backgroundColor: const Color(0xFF1D7A82), // Teal
          centerTitle: true,
          actions: [
            IconButton(
              icon: const Icon(Icons.logout, color: Colors.white),
              onPressed: () => Navigator.pushReplacement(context, MaterialPageRoute(builder: (context) => const LoginScreen())),
            )
          ],
          bottom: const TabBar(
            indicatorColor: Color(0xFF8A1C26),
            labelColor: Colors.white,
            unselectedLabelColor: Colors.white70,
            tabs: [
              Tab(icon: Icon(Icons.video_library), text: 'المحاضرات'),
              Tab(icon: Icon(Icons.quiz), text: 'قسم الحل'),
              Tab(icon: Icon(Icons.picture_as_pdf), text: 'ملفات PDF'),
            ],
          ),
        ),
        body: TabBarView(
          children: [
            _buildFirebaseSection('محاضرات'),
            _buildFirebaseSection('قسم الحل'),
            _buildFirebaseSection('ملفات PDF'),
          ],
        ),
      ),
    );
  }

  // بناء القائمة بشكل حي ومباشر من الـ Firestore بناءً على القسم المختط
  Widget _buildFirebaseSection(String sectionName) {
    return StreamBuilder<QuerySnapshot>(
      stream: FirebaseFirestore.instance
          .collection('physio_content')
          .where('section', ==: sectionName)
          .orderBy('createdAt', descending: true) // الأحدث يظهر أولاً
          .snapshots(),
      builder: (context, snapshot) {
        if (snapshot.hasError) {
          return const Center(child: Text('حدث خطأ أثناء تحميل البيانات'));
        }
        if (snapshot.connectionState == ConnectionState.waiting) {
          return const Center(child: CircularProgressIndicator());
        }
        
        final docs = snapshot.data!.docs;

        if (docs.isEmpty) {
          return const Center(child: Text('لا يوجد محتوى متوفر في هذا القسم حالياً.'));
        }

        return ListView.builder(
          padding: const EdgeInsets.all(12),
          itemCount: docs.length,
          itemBuilder: (context, index) {
            final data = docs[index].data() as Map<String, dynamic>;
            final String title = data['title'] ?? 'بدون عنوان';
            final String url = data['url'] ?? '';

            return Card(
              elevation: 2,
              margin: const EdgeInsets.symmetric(vertical: 8),
              child: ListTile(
                leading: Icon(
                  sectionName == 'محاضرات' ? Icons.play_circle_fill : (sectionName == 'قسم الحل' ? Icons.assignment : Icons.description),
                  color: const Color(0xFF1D7A82),
                  size: 36,
                ),
                title: Text(title, style: const TextStyle(fontWeight: FontWeight.bold)),
                subtitle: const Text('اضغط للمشاهدة أو الاستعراض المباشر'),
                trailing: const Icon(Icons.arrow_forward_ios, size: 16),
                onTap: () {
                  if (sectionName == 'محاضرات') {
                    String? videoId = YoutubePlayer.convertUrlToId(url);
                    if (videoId != null) {
                      Navigator.push(context, MaterialPageRoute(builder: (context) => SafeVideoPlayerScreen(videoId: videoId)));
                    } else {
                      ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text('رابط الفيديو غير صالح')));
                    }
                  } else {
                    ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text('جاري فتح الرابط الآمن: $url')));
                  }
                },
              ),
            );
          },
        );
      },
    );
  }
}

// -----------------------------------------------------------------
// 4. مشغل الفيديو الآمن والمحمي (Safe Video Player)
// -----------------------------------------------------------------
class SafeVideoPlayerScreen extends StatefulWidget {
  final String videoId;
  const SafeVideoPlayerScreen({Key? key, required this.videoId}) : super(key: key);

  @override
  State<SafeVideoPlayerScreen> createState() => _SafeVideoPlayerScreenState();
}

class _SafeVideoPlayerScreenState extends State<SafeVideoPlayerScreen> {
  late YoutubePlayerController _controller;

  @override
  void initState() {
    super.initState();
    _controller = YoutubePlayerController(
      initialVideoId: widget.videoId,
      flags: const YoutubePlayerFlags(
        autoPlay: true,
        mute: false,
        disableDragSeek: false,
        loop: false,
        isLive: false,
        forceHD: true,
        enableCaption: false,
      ),
    );
  }

  @override
  void dispose() {
    _controller.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('المشغل الآمن للمحاضرة', style: TextStyle(color: Colors.white)),
        backgroundColor: const Color(0xFF1D7A82),
      ),
      body: Center(
        child: YoutubePlayer(
          controller: _controller,
          showVideoProgressIndicator: true,
          progressIndicatorColor: const Color(0xFF8A1C26),
        ),
      ),
    );
  }
}
